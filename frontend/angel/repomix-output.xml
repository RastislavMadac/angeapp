    flex-grow: 1;
    white-space: pre-line;
    /* Zabezpečí, že \n vytvorí nový riadok */
    line-height: 1.4;
}

.toast-notification {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 9999;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;

    min-width: 320px;
    max-width: 450px;
