    align-items: center;
    justify-content: center;
}

.close-toast:hover {
    background-color: rgba(0, 0, 0, 0.05);
    color: #374151;
}


/* =========================================
     2. CONFIRM DIALÓG (Stred obrazovky)
     ========================================= */

.notification-confirm {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10000;

    width: 90%;
    max-width: 400px;
    padding: 32px 24px 24px;
    /* Viac miesta hore kvôli X */

