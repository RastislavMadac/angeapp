:root {
    --primary: #2563eb;
    --success: #22c55e;
    --danger: #ef4444;
    --bg: #f8fafc;
    --text: #1e293b;
    --border: #e2e8f0;
}

body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background-color: var(--bg);
    color: var(--text);
    margin: 0;
    padding: 20px;
    line-height: 1.6;
}

.dashboard {
    max-width: 1100px;
    margin: 0 auto;
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
}

header {
    border-bottom: 2px solid var(--border);
    margin-bottom: 30px;
    padding-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

h1 {
    margin: 0;
    font-size: 1.8rem;
    color: var(--primary);
}

/* SEKCIU METODIKY */
.inspection-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
    margin-bottom: 40px;
}

.inspection-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    background: #ffffff;
    display: flex;
    flex-direction: column;
}

.inspection-card h2 {
    margin-top: 0;
    font-size: 1.3rem;
    color: var(--text);
    border-left: 4px solid var(--primary);
    padding-left: 10px;
}

.instruction-text {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 15px;
    flex-grow: 1;
}

/* OBRÁZKY */
.img-container {
    position: relative;
    height: 200px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    background: #f1f5f9;
}

.img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.img-container:hover img {
    transform: scale(1.05);
}

.img-container::after {
    content: "🔍 Klikni pre detail";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    text-align: center;
    font-size: 0.8rem;
    padding: 5px;
    opacity: 0;
    transition: opacity 0.3s;
}

.img-container:hover::after {
    opacity: 1;
}

/* TABUĽKA */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
}

th {
    text-align: left;
    background: #f8fafc;
    padding: 12px;
    border-bottom: 2px solid var(--border);
}

td {
    padding: 12px;
    border-bottom: 1px solid var(--border);
}

.status-select {
    padding: 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
}

/* MODAL / LIGHTBOX */
.modal {
    display: none;
    position: fixed;
    z-index: 9999;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    justify-content: center;
    align-items: center;
}

.modal img {
    max-width: 90%;
    max-height: 90%;
    border-radius: 5px;
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
}

.close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: white;
    font-size: 40px;
    cursor: pointer;
}

.btn-group {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 30px;
}

.btn {
    padding: 10px 25px;
    border-radius: 6px;
    border: none;
    font-weight: bold;
    cursor: pointer;
}

.btn-save {
    background: var(--primary);
    color: white;
}

@media (max-width: 768px) {
    .inspection-grid {
        grid-template-columns: 1fr;
    }
}
