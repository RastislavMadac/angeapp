    </div>

    <div class="cards-grid">
      
      <div class="card">
        <h3><i class="icon-briefcase"></i> Firemné údaje</h3>
        <div class="input-group">
          <label>Internet ID</label>
          <input formControlName="internet_id">
        </div>
        <div class="row-3">
          <div class="input-group">
            <label>IČO</label>
            <input formControlName="ico">
          </div>
