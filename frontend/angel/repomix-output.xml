    border-left-color: #ef4444;
}

/* Červená */

/* Ikonka/Text správy */
.message {
    flex-grow: 1;
}

/* Tlačidlo X na toaste */
.close-toast {
    background: transparent;
    border: none;
    color: #9ca3af;
    font-size: 1.2rem;
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    transition: all 0.2s ease;
    line-height: 1;
