    /* Moderný Glass efekt */
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    /* Jemný tieň a zaoblenie */
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.15);
    border-radius: 12px;
